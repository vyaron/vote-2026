# Environment variables for the Knesset 2026 webapp
# Copy this file to .env.local for local development

# Site URL (for SEO, OG images, sitemap)
# Set this in Vercel dashboard for production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base URL for API calls (usually same as site URL)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Analytics (optional)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=knesset2026.vercel.app
