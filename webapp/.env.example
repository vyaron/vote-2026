# Environment variables for the Knesset 2026 webapp
# Copy this file to .env.local for local development

# Site URL (for SEO, OG images, sitemap)
# Set this in Vercel dashboard for production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base URL for API calls (usually same as site URL)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Analytics (optional)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=knesset2026.vercel.app

# Supabase — create project at https://supabase.com/dashboard
# Copy Project URL and anon key from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to the browser
# Used by the invite script and admin API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Unsplash photo suggestions (photo picker in brief form)
# Get a free key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
