{
  "name": "knesset-scraper",
  "version": "1.0.0",
  "description": "Scraper for Israeli Knesset member data",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "explore": "tsx src/explore.ts",
    "scrape": "tsx src/index.ts",
    "scrape:mks": "tsx src/index.ts --step=mks",
    "scrape:photos": "tsx src/index.ts --step=photos",
    "scrape:parties": "tsx src/index.ts --step=parties",
    "scrape:bills": "tsx src/index.ts --step=bills",
    "scrape:summary": "tsx src/index.ts --step=summary",
    "scrape:resume": "tsx src/index.ts --resume",
    "proxy": "tsx src/rss-proxy.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
